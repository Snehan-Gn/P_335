<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P_335.MainPage"
             BackgroundColor="White">

    <Grid RowDefinitions="Auto, *, Auto">

        <VerticalStackLayout Grid.Row="0" BackgroundColor="#8000FF" Padding="20, 40, 20, 20">
            <Label Text="Flashcards" 
                   TextColor="White" 
                   FontSize="32" 
                   FontAttributes="Bold, Italic" />
        </VerticalStackLayout>

        <ScrollView Grid.Row="1" Padding="20">
            <VerticalStackLayout Spacing="20">
                <Label Text="Mes decks" 
                       TextColor="Black" 
                       FontSize="22" 
                       Margin="0, 10" />

                <CollectionView x:Name="DecksCollection">
                    <CollectionView.ItemsLayout>
                        <LinearItemsLayout Orientation="Vertical" ItemSpacing="20" />
                    </CollectionView.ItemsLayout>
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Frame CornerRadius="20" HasShadow="True" Padding="0" IsClippedToBounds="True" BorderColor="Transparent">
                                <StackLayout>
                                    <BoxView HeightRequest="120" Color="Black" />
                                    <Label Text="{Binding Name}" 
                                           BackgroundColor="#8000FF" 
                                           TextColor="White" 
                                           HorizontalTextAlignment="Center" 
                                           Padding="10" 
                                           FontSize="18" />
                                </StackLayout>
                            </Frame>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>
    </Grid>
</ContentPage>