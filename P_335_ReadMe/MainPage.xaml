<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="P_335_ReadMe.MainPage"
             BackgroundColor="#FDFBFA">

    <Grid RowDefinitions="Auto, *, Auto">

        <Border Grid.Row="0" 
                StrokeThickness="0"
                HeightRequest="130"
                VerticalOptions="Start">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="0,0,0,0" />
            </Border.StrokeShape>
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                    <GradientStop Color="#2D5F58" Offset="0.1" />
                    <GradientStop Color="#1A4A43" Offset="1.0" />
                </LinearGradientBrush>
            </Border.Background>
            <Label Text="ReadMe" 
                   TextColor="#F5F1E6" 
                   FontSize="36" 
                   FontAttributes="Bold"
                   FontFamily="Georgia"
                   HorizontalOptions="Start" 
                   VerticalOptions="Center" 
                   Margin="30,30,0,0">
                <Label.Shadow>
                    <Shadow Brush="Black" Offset="0,2" Radius="3" Opacity="0.3"/>
                </Label.Shadow>
            </Label>
        </Border>

        <ScrollView Grid.Row="1" Padding="25">
            <VerticalStackLayout Spacing="20">
                <Label Text="Mes Livres" 
                       TextColor="#2D5F58" 
                       FontSize="26" 
                       FontAttributes="Bold" />

                <CollectionView x:Name="BooksCollection">
                    <CollectionView.ItemTemplate>
                        <DataTemplate>
                            <Border Margin="0,5,0,15" StrokeThickness="0" BackgroundColor="#2D5F58">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="25" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="Black" Offset="5,5" Radius="15" Opacity="0.2" />
                                </Border.Shadow>

                                <Grid ColumnDefinitions="110, *">
                                    <Border Grid.Column="0" Margin="10,10,0,10" StrokeThickness="0">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="15"/>
                                        </Border.StrokeShape>
                                        <BoxView Color="#FDFBFA" Opacity="0.1" />
                                    </Border>

                                    <StackLayout Grid.Column="1" Padding="15" VerticalOptions="Center">
                                        <Label Text="{Binding Title}" TextColor="#F5F1E6" FontSize="22" FontAttributes="Bold" />

                                        <BoxView HeightRequest="1" Color="#B08968" Margin="0,8" />

                                        <Label Text="{Binding Author}" TextColor="#F5F1E6" FontAttributes="Italic" FontSize="18" Opacity="0.9" />

                                        <HorizontalStackLayout Spacing="8" Margin="0,12,0,0">
                                            <Label Text="Note :" TextColor="#F5F1E6" VerticalOptions="Center" FontSize="16"/>
                                            <Label Text="★★★★★" TextColor="#B08968" FontSize="20" />
                                        </HorizontalStackLayout>
                                    </StackLayout>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </CollectionView.ItemTemplate>
                </CollectionView>
            </VerticalStackLayout>
        </ScrollView>

        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20" Padding="25">

            <Border WidthRequest="50" HeightRequest="50" StrokeThickness="0" BackgroundColor="#2D5F58">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>
                <Border.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.3"/>
                </Border.Shadow>
                <Label Text="1" TextColor="#F5F1E6" HorizontalOptions="Center" VerticalOptions="Center" FontSize="20" FontAttributes="Bold"/>
            </Border>

            <Border WidthRequest="50" HeightRequest="50" BackgroundColor="Transparent" Stroke="#2D5F58" StrokeThickness="2">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="25" />
                </Border.StrokeShape>
                <Label Text="2" TextColor="#2D5F58" HorizontalOptions="Center" VerticalOptions="Center" FontSize="18"/>
            </Border>

            <ImageButton Source="arrow_right.png" 
                         BackgroundColor="#2D5F58" 
                         WidthRequest="50" 
                         HeightRequest="50" 
                         CornerRadius="25" 
                         Padding="12">
                <ImageButton.Shadow>
                    <Shadow Brush="Black" Offset="0,4" Radius="8" Opacity="0.3"/>
                </ImageButton.Shadow>
            </ImageButton>

        </HorizontalStackLayout>

    </Grid>
</ContentPage>