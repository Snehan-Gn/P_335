<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:local="clr-namespace:P_335_ReadMe"
             x:Class="P_335_ReadMe.MainPage"
             BackgroundColor="#F0F4F0">

    <ContentPage.Resources>
        <local:ByteArrayToImageConverter x:Key="ByteArrayToImageConverter" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto, *, Auto">
        <BoxView Grid.Row="0" Color="#2E7D32" HeightRequest="60" />
        <Label Grid.Row="0" Text="Ma Bibliothèque" TextColor="White" 
               FontSize="24" FontAttributes="Bold" HorizontalOptions="Center" VerticalOptions="Center" />

        <CollectionView x:Name="BooksCollection" Grid.Row="1" Margin="10"
                        SelectionMode="Single" SelectionChanged="OnBookSelected">
            <CollectionView.ItemsLayout>
                <GridItemsLayout Orientation="Vertical" Span="2" HorizontalItemSpacing="10" VerticalItemSpacing="10" />
            </CollectionView.ItemsLayout>
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame BackgroundColor="White" BorderColor="#A5D6A7" CornerRadius="10" Padding="0" HasShadow="True">
                        <VerticalStackLayout Spacing="5" Padding="10">
                            <!-- Image avec fallback si nulle -->
                            <Grid HeightRequest="150">
                                <BoxView Color="#E8F5E9" CornerRadius="5" />
                                <Image Source="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}}" 
                                       Aspect="AspectFill" />
                                <Label Text="📖" HorizontalOptions="Center" VerticalOptions="Center" FontSize="40"
                                       IsVisible="{Binding CoverImage, Converter={StaticResource ByteArrayToImageConverter}, ConverterParameter='Inverse'}" />
                            </Grid>
                            
                            <Label Text="{Binding Title}" FontAttributes="Bold" MaxLines="2" LineBreakMode="TailTruncation" TextColor="#1B5E20" />
                            <Label Text="{Binding Author}" FontSize="12" TextColor="#4CAF50" />
                            
                            <!-- Indicateur de statut du fichier -->
                            <Label Text="Fichier manquant" FontSize="10" TextColor="Red" HorizontalOptions="End">
                                <Label.Triggers>
                                    <DataTrigger TargetType="Label" Binding="{Binding EpubData.Length}" Value="0">
                                        <Setter Property="IsVisible" Value="True" />
                                    </DataTrigger>
                                </Label.Triggers>
                            </Label>
                        </VerticalStackLayout>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>

        <Grid x:Name="ReaderContainer" Grid.Row="0" Grid.RowSpan="3" IsVisible="False" BackgroundColor="White">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="60" />
            </Grid.RowDefinitions>
            <Button Text="Fermer la lecture" Clicked="OnCloseReaderClicked" BackgroundColor="#2E7D32" TextColor="White" CornerRadius="0" />
            <WebView x:Name="ReaderView" Grid.Row="1" />
            <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="20">
                <Button Text="Précédent" Clicked="OnPreviousClicked" BackgroundColor="#4CAF50" TextColor="White" WidthRequest="120" />
                <Button Text="Suivant" Clicked="OnNextClicked" BackgroundColor="#4CAF50" TextColor="White" WidthRequest="120" />
            </HorizontalStackLayout>
        </Grid>

        <HorizontalStackLayout Grid.Row="2" HorizontalOptions="Center" Spacing="10" Padding="10">
            <Button Text=" + Importer Epub" Clicked="OnImportClicked" BackgroundColor="#2E7D32" TextColor="White" CornerRadius="25" />
            <Entry x:Name="TagFilter" Placeholder="Filtrer..." WidthRequest="200" TextChanged="OnFilterChanged" />
        </HorizontalStackLayout>
    </Grid>
</ContentPage>